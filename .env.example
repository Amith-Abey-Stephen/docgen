# MongoDB connection string
DATABASE_URL=mongodb://127.0.0.1:27017/docgen

# Cloudinary Branding Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional: used by Next.js when starting production with `npm run start`
PORT=3000
NODE_ENV=development
